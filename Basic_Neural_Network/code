#가장 기본적인 Neural Network
import math

w1 = 2.74
w2 = -1.13
b1 = 0
b2 = 0
w3 = 0.36
w4 = 0.63
b3 = 0
#low -> 0, mid -> 0.5, max -> 1 // x축
low_dos = 0
